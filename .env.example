# GitHub App configuration
# ------------------------
# These values come from your GitHub App settings page.
GITHUB_APP_ID=123456 # Numeric App ID
GITHUB_APP_PRIVATE_KEY="--PRIVATE KEY---" # PEM contents (can also be a file path you read in your code later)
GITHUB_WEBHOOK_SECRET=change-me-webhook-secret


# Web server
# ----------
PORT=3000 # Fastify server port for /health and /webhook


# Redis / queue
# -------------
# Used by BullMQ locally. On AWS, the queue is SQS instead.
REDIS_HOST=redis # docker-compose service name (or localhost)
REDIS_PORT=6379 # Redis port


# Choose which provider Revelio should use. One of: claude, openai, gemini
LLM_PROVIDER=claude


# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key


# OpenAI
OPENAI_API_KEY=your-openai-api-key


# Google Gemini
GEMINI_API_KEY=your-gemini-api-key


# Optional: model overrides
# -------------------------
# If unset, Revelio picks sane defaults per provider (see src/llm/factory.ts).
LLM_MODEL=sonnet-4.6 # Model to use for the LLM


# Optional: LLM rate limiting (avoid burning tokens / 429s)
# ---------------------------------------------------------
# REVELIO_LLM_MIN_DELAY_MS=2000   # Min ms between LLM calls (default: 2000)
# REVELIO_LLM_MAX_CONCURRENT=1    # Max concurrent LLM calls per worker (default: 1)

